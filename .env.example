# Environment configuration example

# Ports
PORT=3001

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# PostgreSQL Configuration
# Used by NestJS/Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/instagram_automation?schema=public"

# Redis Configuration (BullMQ / Key-value cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Meta Developer / Graph API credentials (for Instagram OAuth & Webhooks)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
META_REDIRECT_URI=http://localhost:3001/meta/callback
META_GRAPH_API_VERSION=v20.0

# Encryption Key (32-character string for AES-256)
TOKEN_ENCRYPTION_KEY=12345678901234567890123456789012

